{
  "name": "nrrule.pages.dev",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucking7/esdeath-main.git"
  },
  "type": "commonjs",
  "scripts": {
    "node": "SWC_NODE_IGNORE_DYNAMIC=true node -r @swc-node/register",
    "dexnode": "SWC_NODE_IGNORE_DYNAMIC=true dexnode -r @swc-node/register",
    "build": "pnpm run node ./Build/index.ts",
    "build-profile": "pnpm run dexnode -r @swc-node/register ./Build/index.ts",
    "build-web": "pnpm run node ./Build/build-public.ts",
    "download-geoip": "pnpm run node ./Build/download-geoip.ts",
    "download-fmz200-split": "pnpm run node ./Build/download-fmz200-split.ts",
    "sync-mirrors": "pnpm run node ./Build/sync-mirrors.ts",
    "convert-plugins": "pnpm run node ./Build/convert-plugins.ts",
    "merge-modules": "pnpm run node ./Build/merge-modules.ts",
    "mirror:iringo": "pnpm run node ./Build/sync-mirrors.ts iRingo",
    "mirror:dualsubs": "pnpm run node ./Build/sync-mirrors.ts DualSubs",
    "mirror:biliuniverse": "pnpm run node ./Build/sync-mirrors.ts BiliUniverse",
    "script-hub:start": "./scripts/start-script-hub.sh start",
    "script-hub:stop": "./scripts/start-script-hub.sh stop",
    "script-hub:status": "./scripts/start-script-hub.sh status",
    "script-hub:remove": "./scripts/start-script-hub.sh remove",
    "lint": "eslint --format=sukka .",
    "lint:fix": "eslint --format=sukka --fix .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm run lint && pnpm run typecheck",
    "validate:rules": "node -r @swc-node/register Build/lib/validators/rule-validator.ts",
    "security:audit": "pnpm audit --production",
    "security:check": "pnpm audit && pnpm run validate",
    "deploy": "pnpm build && echo 'Ready for GitHub Pages deployment'",
    "workflow:modules": "pnpm run convert-plugins && pnpm run merge-modules"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ghostery/adblocker": "^2.12.5",
    "@henrygd/queue": "^1.2.0",
    "@mitata/counters": "^0.0.8",
    "better-sqlite3": "^12.5.0",
    "ci-info": "^4.3.0",
    "cli-progress": "^3.12.0",
    "csv-parse": "^6.1.0",
    "dns2": "github:lsongdev/node-dns#e4fa035aca0b8eb730bde3431fbf0c60a31a09c9",
    "domain-alive": "^0.1.11",
    "fast-cidr-tools": "^0.3.2",
    "fast-fifo": "^1.3.2",
    "fast-uri": "^3.1.0",
    "fdir": "^6.5.0",
    "foxts": "^5.0.2",
    "hash-wasm": "^4.12.0",
    "json-stringify-pretty-compact": "3.0.0",
    "null-prototype-object": "^1.2.5",
    "picocolors": "^1.1.1",
    "punycode": "^2.3.1",
    "tar-fs": "^3.1.0",
    "tldts": "^7.0.22",
    "tldts-experimental": "^7.0.19",
    "undici": "^7.15.0",
    "undici-cache-store-better-sqlite3": "^1.0.0",
    "worktank": "^3.0.2",
    "xbits": "^0.2.0",
    "yaml": "^2.8.1",
    "yauzl-promise": "^4.0.0"
  },
  "devDependencies": {
    "@eslint-sukka/node": "^8.0.5",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^24.10.1",
    "@types/punycode": "^2.1.4",
    "eslint": "^9.39.1",
    "eslint-config-sukka": "^8.0.5",
    "eslint-formatter-sukka": "^6.23.1",
    "tinyexec": "^1.0.2",
    "typescript": "^5.9.3",
    "why-is-node-running": "^3.2.2"
  },
  "packageManager": "pnpm@10.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "unrs-resolver"
    ],
    "overrides": {
      "eslint>chalk": "npm:picocolors@^1.1.1",
      "globalthis": "npm:@nolyfill/globalthis@^1.0.44",
      "has": "npm:@nolyfill/has@^1.0.44",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1.0.44"
    },
    "ignoredBuiltDependencies": [
      "bufferutil",
      "es5-ext",
      "utf-8-validate"
    ]
  }
}
