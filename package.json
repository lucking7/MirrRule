{
	"name": "sync-rules",
	"version": "1.0.0",
	"description": "sync-rules",
	"type": "module",
	"scripts": {
		"sync:rules": "NODE_NO_WARNINGS=1 NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/main.ts",
		"sync:mirror": "NODE_NO_WARNINGS=1 NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/module-sync.ts",
		"sync": "npm run sync:rules && npm run sync:mirror",
		"build": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/index.ts",
		"build:temp": "OUTPUT_DIR=$(mktemp -d) NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/index.ts && echo \"构建完成，输出到临时目录: $OUTPUT_DIR\"",
		"build:clean": "npm run build && rm -rf public",
		"build:reject": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/build-reject-domainset.ts",
		"build:common": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/build-common.ts",
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "npm run sync && npm run build",
		"merge": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/merge.ts",
		"render:template": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/render_template.ts",
		"validate:rules": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/validate-rules.ts",
		"validate:domains": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/clean-dead-domains.ts",
		"validate:domain-alive": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/validate-domain-alive.ts",
		"validate:tld": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/validate-illegal-tld.ts",
		"validate:hash": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/validate-hash-collision.ts",
		"validate:rulesyntax": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/validate-rule-syntax.ts",
		"clean:dead-domains": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/clean-dead-domains.ts --fix",
		"clean:dead-domains:preview": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/build/scripts/clean-dead-domains.ts",
		"enhance:modules": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/module-enhancer.ts",
		"process:modules": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/module-processor.ts",
		"validate:modules": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/module-processor.ts --no-fix",
		"fix:modules": "npm run enhance:modules && npm run process:modules",
		"check:reject-tld": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/check-reject-tld.ts",
		"fix:reject-tld": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/check-reject-tld.ts --fix",
		"demo:enhanced-tld": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/demo-enhanced-tld-validation.ts",
		"merge:reject": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/rule-reject-merger.ts",
		"test:reject-merger": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/test-reject-merger.ts",
		"optimize:rules": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/rule-optimizer.ts",
		"optimize:rules:dry": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/rule-optimizer.ts --dry-run",
		"optimize:rules:help": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/sync/rule-optimizer.ts --help",
		"validate:all": "npm run validate:rules && npm run validate:tld && npm run check:reject-tld",
		"test:classifier": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/test-ruleset-classifier.ts",
		"scan:rulesets": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/scan-rulesets.ts",
		"test:ruleset": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" tsx Chores/engineering/scripts/test-specific-ruleset.ts"
	},
	"dependencies": {
		"@henrygd/queue": "^1.0.7",
		"@types/better-sqlite3": "^7.6.13",
		"@types/js-yaml": "^4.0.9",
		"async-retry": "^1.3.3",
		"axios": "^1.8.4",
		"better-sqlite3": "^11.10.0",
		"ci-info": "^4.3.0",
		"cli-progress": "^3.12.0",
		"dns2": "^2.1.0",
		"esbuild-wasm": "^0.19.11",
		"fdir": "^6.4.6",
		"foxts": "^3.7.0",
		"handlebars": "^4.7.8",
		"handlebars-helpers": "^0.10.0",
		"hash-wasm": "^4.12.0",
		"js-yaml": "^4.1.0",
		"node-fetch": "^3.3.2",
		"picocolors": "^1.1.1",
		"tldts": "^7.0.10",
		"tldts-experimental": "^7.0.10",
		"tsx": "^4.7.1",
		"undici": "^7.10.0",
		"undici-cache-store-better-sqlite3": "^1.0.0",
		"whoiser": "^2.0.0-beta.6",
		"xxhash-wasm": "^1.1.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"main": "index.js",
	"devDependencies": {
		"@types/async-retry": "^1.4.9",
		"@types/cli-progress": "^3.11.6",
		"@types/glob": "^8.1.0",
		"@types/handlebars": "^4.1.0",
		"@types/handlebars-helpers": "^0.5.6",
		"@types/node": "^22.14.1",
		"@types/punycode": "^2.1.4",
		"fast-cidr-tools": "^0.3.2",
		"glob": "^11.0.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.3"
	},
	"keywords": [],
	"author": "",
	"license": "ISC"
}
