{
  "name": "nrrule.pages.dev",
  "version": "0.0.0",
  "private": true,
  "description": "Aggregates upstream proxy rules and republishes them for Surge, Clash, Loon, and sing-box.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucking7/MirrRule.git"
  },
  "type": "commonjs",
  "scripts": {
    "node": "SWC_NODE_IGNORE_DYNAMIC=true node -r @swc-node/register",
    "build": "pnpm run node ./Build/index.ts",
    "build-web": "pnpm run node ./Build/build-public.ts",
    "download-geoip": "pnpm run node ./Build/download-geoip.ts",
    "download-fmz200-split": "pnpm run node ./Build/download-fmz200-split.ts",
    "sync-mirrors": "pnpm run node ./Build/sync-mirrors.ts",
    "convert-plugins": "pnpm run node ./Build/convert-plugins.ts",
    "merge-modules": "pnpm run node ./Build/merge-modules.ts",
    "mirror:iringo": "pnpm run node ./Build/sync-mirrors.ts iRingo",
    "mirror:dualsubs": "pnpm run node ./Build/sync-mirrors.ts DualSubs",
    "mirror:biliuniverse": "pnpm run node ./Build/sync-mirrors.ts BiliUniverse",
    "lint": "eslint --format=sukka .",
    "lint:fix": "eslint --format=sukka --fix .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run node --test Build/__tests__/*.test.ts",
    "validate": "pnpm run lint && pnpm run typecheck",
    "knip": "knip",
    "security:audit": "pnpm audit --production",
    "security:check": "pnpm audit && pnpm run validate",
    "deploy": "pnpm build && echo 'Ready for GitHub Pages deployment'",
    "workflow:modules": "pnpm run convert-plugins && pnpm run merge-modules"
  },
  "author": "lucking7",
  "license": "AGPL-3.0",
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "ci-info": "^4.4.0",
    "domain-alive": "^0.1.22",
    "fast-cidr-tools": "^0.3.2",
    "foxts": "^5.5.1",
    "json-stringify-pretty-compact": "3.0.0",
    "picocolors": "^1.1.1",
    "punycode": "^2.3.1",
    "tar-fs": "^3.1.2",
    "undici": "^8.4.1",
    "undici-cache-store-better-sqlite3": "^1.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint-sukka/node": "^8.9.3",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.30",
    "@types/node": "^25.6.0",
    "@types/punycode": "^2.1.4",
    "eslint": "^9.39.1",
    "eslint-config-sukka": "^8.9.3",
    "eslint-formatter-sukka": "^8.9.3",
    "knip": "^6.15.0",
    "prettier": "^3.7.4",
    "typescript": "^6.0.2",
    "why-is-node-running": "^3.2.2"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": "26.x",
    "pnpm": "10.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "unrs-resolver"
    ],
    "overrides": {
      "eslint>chalk": "npm:picocolors@^1.1.1",
      "globalthis": "npm:@nolyfill/globalthis@^1.0.44",
      "has": "npm:@nolyfill/has@^1.0.44",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1.0.44",
      "picomatch": "^4.0.4"
    },
    "ignoredBuiltDependencies": [
      "bufferutil",
      "es5-ext",
      "utf-8-validate"
    ]
  }
}
