#!name=Remove Ads by fmz200
#!desc=去广告合集
#!arguments=哔哩哔哩-开启:开启,最常访问:auto,过滤置顶评论:开启,空降助手:开启,空降助手弹幕版:关闭
#!arguments-desc=哔哩哔哩-开启: 开启/关闭
最常访问: auto(智能)/true(总是显示)/false(总是隐藏)
过滤置顶评论: 开启/关闭
空降助手: 开启/关闭
空降助手弹幕版: 开启/关闭

[Script]
# 哔哩哔哩_推荐去广告
bilibili_proto = type=http-response,pattern=^https://(grpc.biliapi.net|app.bilibili.com)/bilibili.app.(view.v1.View/View|dynamic.v2.Dynamic/DynAll)$,requires-body=1,binary-body-mode=1,max-size=0,script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/bilibili-proto.js,{{{哔哩哔哩-开启}}}

# 哔哩哔哩_UP主推荐广告[适配ipad端]
bilibili_up = type=http-response,pattern=^https?://(app.bilibili.com|grpc.biliapi.net)/bilibili.app.view.v1.View/View$,requires-body=1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/bilibili-proto.js,argument={{{哔哩哔哩-开启}}}&{{{最常访问}}}&{{{过滤置顶评论}}}&{{{空降助手}}}&{{{空降助手弹幕版}}},{{{哔哩哔哩-开启}}}

# 百度输入法_屏蔽广告
baidu_input_ads = type=http-response,pattern=^https?://mime.baidu.com/v5/start_screen_ads/list,requires-body=1,script-path=https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/BaiduInputMethod/BaiduInputMethod_remove_ads.js,{{{baidu_input_enable}}}

[MITM]
hostname = %APPEND% grpc.biliapi.net, app.bilibili.com, mime.baidu.com